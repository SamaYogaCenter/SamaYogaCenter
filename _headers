# Cache images for 30 days
/images/*
  Cache-Control: public, max-age=2592000

# Cache CSS and JS for 1 hour — short enough to pick up changes quickly
/css/*
  Cache-Control: public, max-age=3600

/js/*
  Cache-Control: public, max-age=3600

# No cache for CMS-editable data — always serve fresh after publish
/data/*
  Cache-Control: no-cache, no-store, must-revalidate

# No cache for admin files — always serve the latest version
/admin/*
  Cache-Control: no-cache, no-store, must-revalidate
